{
  "name": "opencode-autoretry",
  "version": "1.0.0",
  "description": "OpenCode 插件：自动重试中断的 AI 对话",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "install-plugin": "node scripts/install.js",
    "typecheck": "tsc --noEmit",
    "diagnose": "node scripts/diagnose.js",
    "timeline": "node scripts/session-timeline.js",
    "errors": "node scripts/error-lookup.js",
    "trace": "node scripts/retry-trace.js"
  },
  "keywords": ["opencode", "plugin", "autoretry", "ai"],
  "author": "rayn1314",
  "license": "MIT",
  "devDependencies": {
    "@opencode-ai/plugin": "latest",
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0"
  }
}